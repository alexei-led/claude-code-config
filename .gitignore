# =============================================================================
# Tracked project config (negates global .gitignore)
# =============================================================================

!.claude/
.claude/*
!.claude/CLAUDE.md

# =============================================================================
# Claude Code Runtime & Cache
# =============================================================================

# Database and cache
__store.db
cache/
image-cache/
paste-cache/
stats-cache.json

# Session data
history.jsonl
session-env/
shell-snapshots/
plans/
todos/
tasks/
file-history/

# Debug and telemetry
debug/
statsig/
telemetry/

# =============================================================================
# Local Configuration (machine-specific)
# =============================================================================

settings.local.json

# =============================================================================
# IDE & Plugins (installed separately)
# =============================================================================

ide/
plugins/
powerline/

# =============================================================================
# Project-specific data
# =============================================================================

projects/

# =============================================================================
# Scripts runtime
# =============================================================================

scripts/__pycache__/

# =============================================================================
# OS Generated
# =============================================================================

.DS_Store
*.swp
*.swo
*~

# =============================================================================
# Secrets (should NEVER be committed)
# =============================================================================

*.key
*.pem
.env
.env.*
credentials.json
# Machine-specific team configs
.claude-team-*
