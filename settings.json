{
  "env": {
    "__CLAUDE_CODE_USE_VERTEX": "1",
    "__CLOUD_ML_REGION": "global",
    "__ANTHROPIC_VERTEX_PROJECT_ID": "alexei-playground-457008"
  },
  "includeCoAuthoredBy": false,
  "permissions": {
    "allow": [
      "mcp__sequential-thinking__sequentialthinking",
      "mcp__morphllm__read*",
      "mcp__morphllm__list*",
      "mcp__morphllm__get*",
      "mcp__morphllm__directory_tree",
      "mcp__morphllm__search*",
      "mcp__perplexity-ask__perplexity_ask",
      "mcp__context7__resolve-library-id",
      "mcp__context7__get-library-docs",
      "mcp__ref__ref_search_documentation",
      "mcp__ref__ref_read_url",
      "Bash(sg:*)",
      "Bash(bat:*)",
      "Bash(fd:*)",
      "Bash(go test:*)",
      "Bash(go vet:*)",
      "Bash(go fmt:*)",
      "Bash(golangci-lint:*)",
      "Bash(mockery:*)",
      "Bash(kubectl:*)",
      "Bash(helm:*)",
      "Bash(kustomize:*)",
      "Bash(bash:*)",
      "Bash(rg:*)",
      "Bash(sd:*)",
      "WebFetch",
      "WebSearch"
    ],
    "ask": [
      "mcp__morphllm__edit_file",
      "mcp__morphllm__wtite_file",
      "mcp__morphllm__tiny_edit_file",
      "mcp__morphllm__create_directory",
      "mcp__morphllm__move_file"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/smart-lint.sh"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/notify.sh"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bunx -y @owloops/claude-powerline --style=powerline",
    "padding": 0
  },
  "alwaysThinkingEnabled": true,
  "model": "sonnet"
}
