{
  "env": {},
  "includeCoAuthoredBy": false,
  "permissions": {
    "allow": [
      "mcp__sequential-thinking__sequentialthinking",
      "mcp__perplexity-ask__perplexity_ask",
      "mcp__context7__resolve-library-id",
      "mcp__context7__query-docs",
      "mcp__gemini__gemini",
      "mcp__gemini__web-search",
      "mcp__gemini__analyze-media",
      "mcp__gemini__shell",
      "mcp__gemini__fetch-chunk",
      "mcp__gemini__ping",
      "mcp__gemini__help",
      "mcp__codex__spawn_agent",
      "mcp__codex__spawn_agents_parallel",
      "mcp__morphllm__warpgrep_codebase_search",
      "mcp__morphllm__codebase_search",
      "mcp__playwright__*",
      "Bash(sg:*)",
      "Bash(bat:*)",
      "Bash(fd:*)",
      "Bash(go test:*)",
      "Bash(go vet:*)",
      "Bash(go fmt:*)",
      "Bash(golangci-lint:*)",
      "Bash(mockery:*)",
      "Bash(kubectl:*)",
      "Bash(helm:*)",
      "Bash(kustomize:*)",
      "Bash(bash:*)",
      "Bash(rg:*)",
      "Bash(sd:*)",
      "Bash(eza:*)",
      "Bash(dust:*)",
      "Bash(procs:*)",
      "Bash(btm:*)",
      "Bash(hyperfine:*)",
      "Bash(tokei:*)",
      "Bash(glow:*)",
      "Bash(zoxide:*)",
      "Bash(difft:*)",
      "Bash(delta:*)",
      "Bash(jq:*)",
      "Bash(yq:*)",
      "Bash(fzf:*)",
      "Bash(tldr:*)",
      "Bash(lazygit:*)",
      "Bash(gopls:*)",
      "Bash(pyright:*)",
      "Bash(eslint:*)",
      "Bash(prettier:*)",
      "Bash(bq:*)",
      "Bash(gcloud:*)",
      "Bash(aws:*)",
      "Bash(uv:*)",
      "Bash(ruff:*)",
      "Bash(terraform:*)",
      "Bash(python3:*)",
      "Bash(npx playwright:*)",
      "Bash(bunx playwright:*)",
      "WebFetch",
      "WebSearch"
    ],
    "ask": [
      "mcp__morphllm__edit_file"
    ]
  },
  "disabledMcpjsonServers": [
    "playwright",
    "codex",
    "gemini"
  ],
  "hooks": {
    "SessionStart": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/session-start.sh",
            "timeout": 3
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/skill-enforcer.sh",
            "timeout": 2
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit|mcp__morphllm__edit_file",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/file-protector.sh",
            "timeout": 2
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit|mcp__morphllm__edit_file",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/smart-lint.sh",
            "timeout": 60
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/notify.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "prompt",
            "prompt": "Evaluate if this subagent should stop. Input: $ARGUMENTS\n\nCheck if:\n- The subagent completed its assigned task\n- Any errors occurred that need fixing\n- Additional context gathering is needed\n\nReturn: {\"decision\": \"approve\" or \"block\", \"reason\": \"explanation\"}"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bunx -y @owloops/claude-powerline",
    "padding": 0
  },
  "enabledPlugins": {
    "gopls-lsp@claude-plugins-official": true,
    "pyright-lsp@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true,
    "atlassian@claude-plugins-official": false,
    "flow-next@gmickel-claude-marketplace": true
  },
  "sandbox": {
    "enabled": true,
    "autoAllowBashIfSandboxed": true,
    "network": {
      "allowAllUnixSockets": true,
      "allowLocalBinding": true
    },
    "excludedCommands": [
      "kubectl",
      "helm",
      "kustomize",
      "docker"
    ],
    "filesystem": {
      "write": {
        "allowOnly": [
          "/Users/alexei/.gemini"
        ]
      }
    }
  },
  "alwaysThinkingEnabled": true,
  "env.vertex": {
    "CLAUDE_CODE_USE_VERTEX": "1",
    "CLOUD_ML_REGION": "global",
    "ANTHROPIC_VERTEX_PROJECT_ID": "alexei-playground-457008",
    "ANTHROPIC_MODEL": "claude-opus-4-5@20251101",
    "ANTHROPIC_DEFAULT_OPUS_MODEL": "claude-opus-4-5@20251101",
    "ANTHROPIC_DEFAULT_HAIKU_MODEL": "claude-haiku-4-5@20251001"
  },
  "env.copilot": {
    "ANTHROPIC_BASE_URL": "http://localhost:4141",
    "ANTHROPIC_MODEL": "claude-opus-4.5",
    "ANTHROPIC_DEFAULT_OPUS_MODEL": "claude-opus-4.5",
    "ANTHROPIC_DEFAULT_SONNET_MODEL": "claude-sonnet-4.5",
    "ANTHROPIC_DEFAULT_HAIKU_MODEL": "claude-haiku-4.5",
    "DISABLE_NON_ESSENTIAL_MODEL_CALLS": "1",
    "CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC": "1",
    "CLAUDE_CODE_ATTRIBUTION_HEADER": "0"
  },
  "env.default": {},
  "env.zai": {
    "apiKeyHelper": "~/.claude/scripts/auth-helper.sh",
    "_keychain": "claude-zai",
    "ANTHROPIC_BASE_URL": "https://api.z.ai/api/anthropic",
    "CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC": "1"
  },
  "_activeEnv": "default",
  "env.deepseek": {
    "apiKeyHelper": "~/.claude/scripts/auth-helper.sh",
    "ANTHROPIC_BASE_URL": "https://api.deepseek.com/anthropic",
    "ANTHROPIC_DEFAULT_OPUS_MODEL": "deepseek-reasoner",
    "ANTHROPIC_DEFAULT_SONNET_MODEL": "deepseek-chat",
    "ANTHROPIC_DEFAULT_HAIKU_MODEL": "deepseek-chat",
    "model": "deepseek-reasoner",
    "MAX_THINKING_TOKENS": "64000",
    "DISABLE_TELEMETRY": "true",
    "_keychain": "deepseek-api"
  }
}
