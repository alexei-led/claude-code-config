{
  "env": {
    "__CLAUDE_CODE_USE_VERTEX": "1",
    "__CLOUD_ML_REGION": "global",
    "__ANTHROPIC_VERTEX_PROJECT_ID": "alexei-playground-457008"
  },
  "includeCoAuthoredBy": false,
  "permissions": {
    "allow": [
      "mcp__sequential-thinking__sequentialthinking",
      "mcp__morphllm__warp_grep",
      "mcp__morphllm__codebase_search",
      "mcp__perplexity-ask__perplexity_ask",
      "mcp__context7__resolve-library-id",
      "mcp__context7__get-library-docs",
      "mcp__ref__ref_search_documentation",
      "mcp__ref__ref_read_url",
      "Bash(sg:*)",
      "Bash(bat:*)",
      "Bash(fd:*)",
      "Bash(go test:*)",
      "Bash(go vet:*)",
      "Bash(go fmt:*)",
      "Bash(golangci-lint:*)",
      "Bash(mockery:*)",
      "Bash(kubectl:*)",
      "Bash(helm:*)",
      "Bash(kustomize:*)",
      "Bash(bash:*)",
      "Bash(rg:*)",
      "Bash(sd:*)",
      "Bash(bq:*)",
      "Bash(gcloud:*)",
      "Bash(aws:*)",
      "Bash(uv:*)",
      "Bash(ruff:*)",
      "Bash(terraform:*)",
      "Bash(python3:*)",
      "mcp__codex__spawn_agent",
      "mcp__gemini__ask-gemini",
      "mcp__gemini__brainstorm",
      "WebFetch",
      "WebSearch"
    ],
    "ask": [
      "mcp__morphllm__edit_file"
    ]
  },
  "disabledMcpjsonServers": [],
  "hooks": {
    "UserPromptSubmit": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/skill-enforcer.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/smart-lint.sh"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/notify.sh"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "prompt",
            "prompt": "Evaluate if this subagent should stop. Input: $ARGUMENTS\n\nCheck if:\n- The subagent completed its assigned task\n- Any errors occurred that need fixing\n- Additional context gathering is needed\n\nReturn: {\"decision\": \"approve\" or \"block\", \"reason\": \"explanation\"}"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bunx -y @owloops/claude-powerline --style=powerline",
    "padding": 0
  },
  "sandbox": {
    "enabled": true,
    "autoAllowBashIfSandboxed": true,
    "network": {
      "allowAllUnixSockets": true,
      "allowLocalBinding": true
    },
    "excludedCommands": [
      "kubectl",
      "helm",
      "kustomize",
      "docker"
    ]
  },
  "alwaysThinkingEnabled": true
}
