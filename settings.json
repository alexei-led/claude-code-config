{
  "env": {},
  "env.vertex": {
    "CLAUDE_CODE_USE_VERTEX": "1",
    "CLOUD_ML_REGION": "global",
    "ANTHROPIC_VERTEX_PROJECT_ID": "alexei-playground-457008",
    "ANTHROPIC_MODEL": "claude-opus-4-5@20251101",
    "ANTHROPIC_DEFAULT_HAIKU_MODEL": "claude-haiku-4-5@20251001"
  },
  "env.copilot": {
    "ANTHROPIC_BASE_URL": "http://localhost:4141",
    "ANTHROPIC_AUTH_TOKEN": "dummy",
    "ANTHROPIC_MODEL": "claude-opus-4.5",
    "ANTHROPIC_DEFAULT_SONNET_MODEL": "claude-sonnet-4.5",
    "ANTHROPIC_DEFAULT_HAIKU_MODEL": "claude-haiku-4.5",
    "DISABLE_NON_ESSENTIAL_MODEL_CALLS": "1",
    "CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC": "1"
  },
  "includeCoAuthoredBy": false,
  "permissions": {
    "allow": [
      "mcp__sequential-thinking__sequentialthinking",
      "mcp__perplexity-ask__perplexity_ask",
      "mcp__context7__resolve-library-id",
      "mcp__context7__get-library-docs",
      "Bash(sg:*)",
      "Bash(bat:*)",
      "Bash(fd:*)",
      "Bash(go test:*)",
      "Bash(go vet:*)",
      "Bash(go fmt:*)",
      "Bash(golangci-lint:*)",
      "Bash(mockery:*)",
      "Bash(kubectl:*)",
      "Bash(helm:*)",
      "Bash(kustomize:*)",
      "Bash(bash:*)",
      "Bash(rg:*)",
      "Bash(sd:*)",
      "Bash(bq:*)",
      "Bash(gcloud:*)",
      "Bash(aws:*)",
      "Bash(uv:*)",
      "Bash(ruff:*)",
      "Bash(terraform:*)",
      "Bash(python3:*)",
      "Bash(gemini:*)",
      "Bash(codex:*)",
      "WebFetch",
      "WebSearch"
    ],
    "ask": []
  },
  "disabledMcpjsonServers": [],
  "hooks": {
    "UserPromptSubmit": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/skill-enforcer.sh",
            "timeout": 2
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/file-protector.sh",
            "timeout": 2
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/smart-lint.sh",
            "timeout": 60
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/notify.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "prompt",
            "prompt": "Evaluate if this subagent should stop. Input: $ARGUMENTS\n\nCheck if:\n- The subagent completed its assigned task\n- Any errors occurred that need fixing\n- Additional context gathering is needed\n\nReturn: {\"decision\": \"approve\" or \"block\", \"reason\": \"explanation\"}"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bunx -y @owloops/claude-powerline --style=powerline",
    "padding": 0
  },
  "sandbox": {
    "enabled": true,
    "autoAllowBashIfSandboxed": true,
    "filesystem": {
      "write": {
        "allowOnly": ["/Users/alexei/.gemini"]
      }
    },
    "network": {
      "allowAllUnixSockets": true,
      "allowLocalBinding": true
    },
    "excludedCommands": [
      "kubectl",
      "helm",
      "kustomize",
      "docker",
      "codex",
      "gemini"
    ]
  },
  "alwaysThinkingEnabled": true,
  "enabledPlugins": {
    "gopls-lsp@claude-plugins-official": true
  }
}
