{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "^apply_patch$",
        "hooks": [
          {
            "type": "command",
            "command": "\"$PLUGIN_ROOT/hooks/file-protector.py\"",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "^Bash$",
        "hooks": [
          {
            "type": "command",
            "command": "\"$PLUGIN_ROOT/hooks/git-guardrails.sh\"",
            "timeout": 10,
            "statusMessage": "Checking git command"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "^apply_patch$",
        "hooks": [
          {
            "type": "command",
            "command": "\"$PLUGIN_ROOT/hooks/smart-lint.sh\"",
            "timeout": 60,
            "statusMessage": "Running smart-lint"
          },
          {
            "type": "command",
            "command": "\"$PLUGIN_ROOT/hooks/test-runner.sh\"",
            "timeout": 120,
            "statusMessage": "Running tests"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$PLUGIN_ROOT/hooks/session-start.py\"",
            "timeout": 5,
            "statusMessage": "Loading session context"
          }
        ]
      }
    ]
  }
}
