def _cliproxy_configs() -> dict[str, dict[str, str]]:
    """Build CLIProxyAPI-based configs (codex/gemini) with resolved URL."""
    url = get_cliproxy_url()
    return {
        "codex": {
            "ANTHROPIC_BASE_URL": url,
            "ANTHROPIC_DEFAULT_OPUS_MODEL": "gpt-5-codex-high",
            "ANTHROPIC_DEFAULT_SONNET_MODEL": "gpt-5-codex",
            "ANTHROPIC_DEFAULT_HAIKU_MODEL": "gpt-5-codex",
            "_proxy": "cliproxy",
        },
        "gemini": {
            "ANTHROPIC_BASE_URL": url,
            "ANTHROPIC_DEFAULT_OPUS_MODEL": "gemini-3-pro-preview",
            "ANTHROPIC_DEFAULT_SONNET_MODEL": "gemini-3-pro-preview",
            "ANTHROPIC_DEFAULT_HAIKU_MODEL": "gemini-3-flash",
            "_proxy": "cliproxy",
        },
    }


def ensure_provider_configs(settings: dict) -> None:
    """Ensure all provider env configs exist in settings."""
    all_configs = {**DEFAULT_CONFIGS, **_cliproxy_configs()}
    for name, config in all_configs.items():
        key = f"env.{name}"
        if key not in settings:
            settings[key] = apply_persistent_env(dict(config))


def get_key() -> str:
    """Read a single keypress.

    Uses os.read() for unbuffered reads so select() can correctly detect
    remaining bytes in escape sequences. Python's sys.stdin.read() buffers
    at the interpreter level, making select() on the fd unreliable.
    """
    fd = sys.stdin.fileno()
    old_settings = termios.tcgetattr(fd)
    try:
        tty.setraw(fd)
        ch = os.read(fd, 1).decode("utf-8", errors="replace")
        if ch == "\x1b":  # Escape sequence
            # Wait for follow-up chars (arrow keys send \x1b[A or \x1bOA)
            if select.select([fd], [], [], 0.15)[0]:
                ch2 = os.read(fd, 1).decode("utf-8", errors="replace")
                # \x1b[ = CSI (normal mode), \x1bO = SS3 (application cursor mode / tmux)
                if ch2 in ("[", "O") and select.select([fd], [], [], 0.15)[0]:
                    ch3 = os.read(fd, 1).decode("utf-8", errors="replace")
                    if ch3 == "A":
                        return "up"
                    elif ch3 == "B":
                        return "down"
            return "esc"
        elif ch in ("\r", "\n"):
            return "enter"
        elif ch == " ":
            return "space"
        elif ch == "q":
            return "esc"
        elif ch == "j":
            return "down"
        elif ch == "k":
            return "up"
        return ch
    finally:
        termios.tcsetattr(fd, termios.TCSADRAIN, old_settings)


def render_menu(envs: list[str], current: str, selected: int, chosen: int | None):
    """Render the interactive menu."""
    # Header
    print()
    print(f"  {BOLD}{CYAN}ce{RESET} {DIM}— Claude Environment Switcher{RESET}")
    print(f"  {DIM}Switch between Claude Code API providers{RESET}")
    print()

    # Menu items
    for i, env in enumerate(envs):
        is_active = env == current
        is_selected = i == selected
        is_chosen = i == chosen

        # Get provider info
        name, desc = PROVIDERS.get(env, (env, ""))

        # Build the line
        if is_selected:
            prefix = f"  {CYAN}❯{RESET} "
            name_style = f"{BOLD}{WHITE}"
            desc_style = CYAN
        else:
            prefix = "    "
            name_style = DIM
            desc_style = DIM

        # Markers: chosen (✓), active (●)
        markers = ""
        if is_chosen:
            markers += f" {GREEN}✓{RESET}"
        if is_active:
            markers += f" {GREEN}●{RESET}"

        # Alias hint
        alias = next((a for a, e in ALIASES.items() if e == env), None)
        alias_hint = f" {DIM}({alias}){RESET}" if alias else ""

        # Description
        desc_text = f"  {desc_style}{desc}{RESET}" if desc else ""

        print(
            f"{CLEAR_LINE}{prefix}{name_style}{name}{RESET}{alias_hint}{markers}{desc_text}"
        )

    # Footer with key mappings
    print()
    print(
        f"  {DIM}↑↓{RESET} move  {DIM}space{RESET} select  {DIM}enter{RESET} run claude  {DIM}esc{RESET} exit"
    )
    print()


def clear_menu(num_lines: int):
    """Clear the rendered menu."""
    for _ in range(num_lines):
        sys.stdout.write(f"{MOVE_UP}{CLEAR_LINE}")
    sys.stdout.flush()


def interactive_select(
    envs: list[str], current: str, settings: dict
) -> tuple[str | None, bool]:
    """Show interactive menu. Returns (env, launch) or (None, False) if cancelled.

    Space immediately switches env (saves to settings).
    Enter launches claude with current active env.
    Returns ("team", True) for team selection - caller handles cc-team launch.
    """
    selected = envs.index(current) if current in envs else 0
    active = current  # Track active env (updated by Space)
    num_lines = (
        len(envs) + 7
    )  # blank + header + desc + blank + items + blank + footer + blank

    print(HIDE_CURSOR, end="", flush=True)
    try:
        render_menu(envs, active, selected, None)

        while True:
            key = get_key()

            if key == "esc":
                clear_menu(num_lines)
                return None, False
            elif key == "enter":
                new_env = envs[selected]
                # Team is special - don't switch env, just signal to launch cc-team
                if new_env == "team":
                    clear_menu(num_lines)
                    return "team", True
                # Switch to selected env (like space) + launch
                if new_env != active:
                    success, _, _ = switch_env(settings, active, new_env)
                    if not success:
                        clear_menu(num_lines)
                        return None, False
                    active = new_env
                clear_menu(num_lines)
                return active, True
            elif key == "space":
                # Switch to selected env immediately (skip for team)
                new_env = envs[selected]
                if new_env != "team" and new_env != active:
                    success, _, _ = switch_env(settings, active, new_env)
                    if success:
                        active = new_env
            elif key == "up":
                selected = (selected - 1) % len(envs)
            elif key == "down":
                selected = (selected + 1) % len(envs)

            clear_menu(num_lines)
            render_menu(envs, active, selected, None)
    finally:
        print(SHOW_CURSOR, end="", flush=True)


def switch_env(
    settings: dict, current: str, target: str
) -> tuple[bool, str | None, str | None]:
    """Switch to target environment. Returns (success, auth_msg, secret)."""
    auth_msg = None
    secret = None

    # Start copilot proxy if switching to copilot and not already running
    # Note: Never auto-stop proxy - other sessions may be using it
    if target == "copilot" and not check_proxy(COPILOT_PROXY):
        if not start_proxy(COPILOT_PROXY):
            return False, None, None  # Failed to start proxy

    # Start CLIProxyAPI if switching to codex or gemini
    if target in ("codex", "gemini") and not check_proxy(CLIPROXY):
        if not start_proxy(CLIPROXY):
            return False, None, None  # Failed to start proxy

    # Save current env from the canonical stored config, not the live "env" dict
    # (live dict may be stale after rapid TUI switches)
    current_env = settings.get(f"env.{current}", settings.get("env", {})).copy()
    current_env.pop("ANTHROPIC_AUTH_TOKEN", None)
    apply_persistent_env(current_env)
    settings[f"env.{current}"] = current_env

    # Load target env config (without secrets for storage)
    target_config = settings.get(f"env.{target}", {}).copy()
    apply_persistent_env(target_config)

    # Store clean config in settings (NO secrets in file!)
    settings["env"] = target_config
    settings["_activeEnv"] = target
    write_settings(settings)

    # Load secret from 1Password (for runtime env export only)
    op_item = target_config.get("_1password")
    if op_item:
        secret = get_1password_secret(op_item)
        if secret:
            auth_msg = f"  {DIM}(key from 1Password: {op_item}){RESET}"
        else:
            auth_msg = f"  {YELLOW}⚠ 1Password item not found: {op_item}{RESET}"

    return True, auth_msg, secret


def show_help():
    """Print help message."""
    print(f"""
{BOLD}{CYAN}ce{RESET} {DIM}— Claude Environment Switcher{RESET}

{DIM}Launchers (auto-wrap in tmux):{RESET}
  ce                    Interactive TUI picker
  ce <env>              Switch + launch (e.g., ce z)
  ce <env> <args>       Switch + launch with args (e.g., ce z --continue)
  ce <args>             TUI picker + launch with args (e.g., ce --continue)
  ce team               Launch Claude Code Team (alias: t)
  ce bot                Start ccbot Telegram bridge (alias: b)

{DIM}Modifiers:{RESET}
  --no-tmux             Skip tmux auto-wrapping

{DIM}Management (no tmux):{RESET}
  --stop-proxy          Stop copilot proxy
  --stop-cliproxy       Stop CLIProxyAPI

{DIM}Environments:{RESET}
  default (max)         Claude Max
  vertex (v)            Google Vertex AI
  copilot (cp)          GitHub Copilot proxy
  zai (z)               z.ai (GLM-4.7 for all)
  deepseek (ds)         DeepSeek (reasoner for Opus, chat for Sonnet/Haiku)
  codex (cx)            OpenAI GPT-5 via CLIProxyAPI
  gemini (gm)           Google Gemini 3 via CLIProxyAPI

{DIM}tmux:{RESET}
  Auto-creates/attaches session '{TMUX_SESSION}' for all launchers
  Skipped when already inside tmux ($TMUX detected)
  Use --no-tmux to force skip

{DIM}Proxies:{RESET}
  Copilot: auto-starts on switch, --stop-proxy to stop
  CLIProxyAPI: cliproxy.sh --login-codex/--login-gemini first time

{DIM}TUI Keys:{RESET}
  ↑↓ / jk               Move cursor
  Space                 Select provider (saves to settings)
  Enter                 Run claude with selected provider
  Esc / q               Exit
""")


def main():
    # Handle --help
    if "--help" in sys.argv or "-h" in sys.argv:
        show_help()
        sys.exit(0)

    # Handle --stop-proxy (copilot)
    if "--stop-proxy" in sys.argv:
        if check_proxy(COPILOT_PROXY):
            stop_proxy(COPILOT_PROXY)
        else:
            print(f"{DIM}Copilot proxy not running{RESET}")
        sys.exit(0)

    # Handle --stop-cliproxy
    if "--stop-cliproxy" in sys.argv:
        if check_proxy(CLIPROXY):
            stop_proxy(CLIPROXY)
        else:
            print(f"{DIM}CLIProxyAPI not running{RESET}")
        sys.exit(0)

    # --- tmux gate: extract --no-tmux, then auto-wrap ---
    no_tmux = "--no-tmux" in sys.argv
    if no_tmux:
        sys.argv.remove("--no-tmux")
    else:
        ensure_tmux()  # re-execs inside tmux if not already there

    try:
        settings = json.loads(SETTINGS.read_text())
    except FileNotFoundError:
        print(f"{YELLOW}⚠ Settings file not found: {SETTINGS}{RESET}")
        print(f"{DIM}Run 'claude' first to create default settings{RESET}")
        sys.exit(1)
    except json.JSONDecodeError as e:
        print(f"{YELLOW}⚠ Invalid settings file: {SETTINGS}{RESET}")
        print(f"{DIM}{e}{RESET}")
        sys.exit(1)

    # Ensure provider configs exist
    ensure_provider_configs(settings)
    write_settings(settings)
    current = settings.get("_activeEnv", "default")

    # Check if team mode is available (after early exits to avoid subprocess overhead)
    team_available = is_team_machine()

    # Get all available environments (PROVIDERS order, then any extras alphabetically)
    env_set = {"default"} | {
        k[4:] for k in settings if k.startswith("env.") and len(k) > 4
    }
    if team_available:
        env_set.add("team")
    env_set.add("bot")
    envs = [e for e in PROVIDERS if e in env_set] + sorted(env_set - set(PROVIDERS))

    # Parse arguments: first arg is env (if valid alias/name), rest goes to claude
    args = sys.argv[1:]
    target = None
    claude_args = []
    launch_claude = False

    if args:
        first = args[0]
        candidate = ALIASES.get(first, first)

        if candidate in envs:
            # First arg is a valid env
            target = candidate
            claude_args = args[1:]
            launch_claude = True  # Direct mode always launches
        else:
            # First arg is not an env → TUI mode with all args passed to claude
            claude_args = args
            target, launch_claude = interactive_select(envs, current, settings)
            if target is None:
                sys.exit(0)
            # If TUI returned launch=True, use claude_args; otherwise ignore them
            if not launch_claude:
                claude_args = []
    else:
        # No args → TUI mode
        target, launch_claude = interactive_select(envs, current, settings)
        if target is None:
            sys.exit(0)

    # Handle bot mode - launch ccbot Telegram bridge
    if target == "bot":
        start_ccbot()  # never returns (execlp)

    # Handle team mode - launch cc-team directly
    if target == "team":
        if not team_available:
            print(f"{YELLOW}⚠ Team mode only available on {TEAM_MACHINE}{RESET}")
            sys.exit(1)

        # Reset env to avoid leaking proxy settings to cc-team
        current_env = settings.get("_activeEnv", "default")
        if current_env not in ("default", "team"):
            # Save current config before clearing
            env_data = settings.get("env", {}).copy()
            env_data.pop("ANTHROPIC_AUTH_TOKEN", None)
            settings[f"env.{current_env}"] = env_data

        # Clear env and reset to default (cc-team uses its own config)
        settings["env"] = apply_persistent_env({})
        settings["_activeEnv"] = "default"
        write_settings(settings)

        current_name = PROVIDERS.get(current_env, (current_env, ""))[0]
        print(f"{BOLD}Claude Code Team{RESET} {DIM}(was: {current_name}){RESET}")
        print(f"\n{DIM}Launching cc-team...{RESET}\n")
        try:
            os.execlp("cc-team", "cc-team", *claude_args)
        except FileNotFoundError:
            print(f"{YELLOW}⚠ cc-team not found in PATH{RESET}")
            sys.exit(1)

    # Reload settings (TUI may have modified via Space)
    settings = json.loads(SETTINGS.read_text())
    current_active = settings.get("_activeEnv", "default")

    # Switch if needed (only for direct CLI mode, TUI already switched via Space)
    secret = None
    if target != current_active:
        success, auth_msg, secret = switch_env(settings, current_active, target)
        if not success:
            print(f"{YELLOW}⚠ Failed to start proxy for {target}{RESET}")
            if target == "copilot":
                print(f"{DIM}Try manually: ~/.claude/scripts/copilot-proxy.sh{RESET}")
            else:
                print(f"{DIM}Try manually: ~/.claude/scripts/cliproxy.sh{RESET}")
                print(f"{DIM}Or login first: cliproxy.sh --login-{target}{RESET}")
            sys.exit(1)
        print(f"{GREEN}●{RESET} {current_active} {DIM}→{RESET} {BOLD}{target}{RESET}")
        if auth_msg:
            print(auth_msg)

    # Load secret for launch (if not already loaded from switch)
    if secret is None:
        target_config = settings.get(f"env.{target}", settings.get("env", {}))
        op_item = target_config.get("_1password")
        if op_item:
            secret = get_1password_secret(op_item)

    # Launch claude if requested
    if launch_claude:
        # Export auth token as env var (never written to file)
        if secret:
            os.environ["ANTHROPIC_AUTH_TOKEN"] = secret
        elif target in ("copilot", "codex", "gemini"):
            # Proxy-based providers don't need real auth - use dummy token
            os.environ["ANTHROPIC_AUTH_TOKEN"] = "sk-dummy"
        print(f"\n{DIM}Launching claude...{RESET}\n")
        try:
            os.execlp("claude", "claude", *claude_args)
        except FileNotFoundError:
            print(f"{YELLOW}⚠ claude not found in PATH{RESET}")
            sys.exit(1)


if __name__ == "__main__":
    try:
        main()
    except KeyboardInterrupt:
        print(f"\n{SHOW_CURSOR}", end="")
        sys.exit(130)
    except Exception as e:
        print(f"\n{SHOW_CURSOR}{YELLOW}Error: {e}{RESET}")
        sys.exit(1)
