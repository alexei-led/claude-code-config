#!/usr/bin/env python3
"""Claude Code environment switcher with interactive TUI.

Usage:
  ce                    # TUI picker → switch + launch claude (auto-tmux)
  ce z                  # Switch to z.ai → launch claude
  ce z --continue       # Switch → launch with claude args
  ce --continue         # TUI picker → launch with claude args
  ce team               # Launch Claude Code Team (alias: t)
  ce bot                # Start ccbot Telegram bridge (alias: b)
  ce --no-tmux          # Skip tmux auto-wrapping
  ce --stop-proxy       # Stop copilot proxy
  ce --stop-cliproxy    # Stop CLIProxyAPI

tmux:
  - Auto-creates/attaches tmux session 'ccbot' for all launchers
  - Detected via $TMUX — skipped when already inside tmux
  - Use --no-tmux to force skip

ccbot (Telegram bridge):
  - Install: uv tool install git+https://github.com/six-ddc/ccbot.git
  - Config: ~/.ccbot/.env
  - Run: ce bot

Copilot proxy:
  - Auto-starts when switching to copilot
  - Use --stop-proxy to stop manually

CLIProxyAPI (codex/gemini):
  - First login: cliproxy.sh --login-codex (or --login-gemini)
  - Auto-starts when switching to codex or gemini
  - Use --stop-cliproxy to stop manually
"""

import json
import os
import select
import socket
import stat
import subprocess
import sys
import tempfile
import termios
import tty
from pathlib import Path

SETTINGS = Path.home() / ".claude" / "settings.json"
TMUX_SESSION = "ccbot"
CCBOT_DIR = Path.home() / ".ccbot"


def write_settings(settings: dict) -> None:
    """Atomically write settings to disk with restricted permissions (0600)."""
    data = json.dumps(settings, indent=2) + "\n"
    fd, tmp_path = tempfile.mkstemp(dir=SETTINGS.parent, suffix=".json.tmp")
    try:
        os.write(fd, data.encode())
        os.close(fd)
        fd = -1
        os.chmod(tmp_path, stat.S_IRUSR | stat.S_IWUSR)
        os.replace(tmp_path, SETTINGS)
    except BaseException:
        if fd >= 0:
            os.close(fd)
        try:
            os.unlink(tmp_path)
        except OSError:
            pass
        raise


# Env vars that must survive all environment switches
PERSISTENT_ENV = {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
}

ALIASES = {
    "max": "default",
    "v": "vertex",
    "cp": "copilot",
    "z": "zai",
    "ds": "deepseek",
    "t": "team",
    "cx": "codex",
    "gm": "gemini",
    "b": "bot",
}

# Machine-specific features
TEAM_MACHINE = "gaia-mbp-m2"


def is_team_machine() -> bool:
    """Check if running on the team-enabled machine."""
    return socket.gethostname().split(".")[0] == TEAM_MACHINE


# Provider descriptions: (display_name, short_description)
PROVIDERS = {
    "default": ("Claude Max", "Opus 4.5 / Sonnet 4"),
    "vertex": ("Vertex AI", "Google Cloud, pay-per-use"),
    "copilot": ("Copilot", "GitHub proxy"),
    "zai": ("z.ai", "GLM-4.7, 200K ctx, 128K out"),
    "deepseek": ("DeepSeek", "128K ctx, 64K out, no cache"),
    "team": ("Claude Code Team", "Work subscription"),
    "codex": ("Codex", "GPT-5 via CLIProxyAPI"),
    "gemini": ("Gemini", "Gemini 3 via CLIProxyAPI"),
    "bot": ("ccbot", "Telegram bridge for tmux sessions"),
}

# ANSI escape codes
RESET = "\033[0m"
BOLD = "\033[1m"
DIM = "\033[2m"
CYAN = "\033[36m"
GREEN = "\033[32m"
YELLOW = "\033[33m"
WHITE = "\033[97m"
BG_CYAN = "\033[46m"
BG_BLACK = "\033[40m"
HIDE_CURSOR = "\033[?25l"
SHOW_CURSOR = "\033[?25h"
CLEAR_LINE = "\033[2K"
MOVE_UP = "\033[A"


def get_1password_secret(item: str) -> str | None:
    """Load secret from 1Password."""
    try:
        result = subprocess.run(
            ["op", "item", "get", item, "--fields", "password", "--reveal"],
            capture_output=True,
            text=True,
            check=True,
        )
        return result.stdout.strip()
    except subprocess.CalledProcessError:
        return None


class ProxyConfig:
    """Configuration for a proxy service."""

    def __init__(self, name: str, script: str, pid_file: str, port: int | None = None):
        self.name = name
        self.script = Path.home() / ".claude" / "scripts" / script
        self.pid_file = Path(os.environ.get("TMPDIR", "/tmp")) / pid_file
        self.port = port


COPILOT_PROXY = ProxyConfig("copilot proxy", "copilot-proxy.sh", "copilot-proxy.pid", port=8318)

def _cliproxy_port() -> int:
    raw = os.environ.get("CLIPROXY_PORT", "8317")
    try:
        return int(raw)
    except ValueError:
        print(f"{YELLOW}⚠ Invalid CLIPROXY_PORT={raw!r}, using 8317{RESET}")
        return 8317

CLIPROXY = ProxyConfig("CLIProxyAPI", "cliproxy.sh", "cliproxy.pid", port=_cliproxy_port())


def is_port_in_use(port: int) -> bool:
    """Check if a port is in use."""
    with socket.socket(socket.AF_INET, socket.SOCK_STREAM) as s:
        return s.connect_ex(("127.0.0.1", port)) == 0


def check_proxy(proxy: ProxyConfig) -> bool:
    """Check if a proxy is running (via PID file or port check)."""
    # First check port - if something is listening, proxy is running
    if proxy.port is not None and is_port_in_use(proxy.port):
        return True
    # Fall back to PID file check
    if not proxy.pid_file.exists():
        return False
    try:
        pid = int(proxy.pid_file.read_text().strip())
        os.kill(pid, 0)
        return True
    except (ValueError, OSError):
        return False


def start_proxy(proxy: ProxyConfig) -> bool:
    """Start a proxy. Returns True if started successfully."""
    if not proxy.script.exists():
        print(f"{YELLOW}⚠ {proxy.name} script not found: {proxy.script}{RESET}")
        return False

    print(f"{DIM}Starting {proxy.name}...{RESET}")
    try:
        result = subprocess.run([str(proxy.script)], capture_output=True, text=True, timeout=15)
    except subprocess.TimeoutExpired:
        print(f"{YELLOW}⚠ {proxy.name} start timed out (15s){RESET}")
        return False
    if result.returncode == 0:
        print(f"{GREEN}✓{RESET} {proxy.name} started")
        return True
    print(f"{YELLOW}⚠ Failed to start {proxy.name}{RESET}")
    if result.stderr:
        print(f"{DIM}{result.stderr.strip()}{RESET}")
    if result.stdout:
        print(f"{DIM}{result.stdout.strip()}{RESET}")
    return False


def stop_proxy(proxy: ProxyConfig) -> None:
    """Stop a proxy if running."""
    if not check_proxy(proxy):
        return
    if proxy.script.exists():
        print(f"{DIM}Stopping {proxy.name}...{RESET}")
        subprocess.run([str(proxy.script), "--stop"], capture_output=True)
        print(f"{GREEN}✓{RESET} {proxy.name} stopped")


def tmux_session_exists(session: str) -> bool:
    """Check if a tmux session exists."""
    return subprocess.run(
        ["tmux", "has-session", "-t", session],
        capture_output=True,
    ).returncode == 0


def ensure_tmux() -> None:
    """If not in tmux, re-exec ce inside a tmux session.

    New session: creates it running ce with original args.
    Existing session: just attaches (user sees current state).
    """
    if os.environ.get("TMUX"):
        return  # Already in tmux

    if tmux_session_exists(TMUX_SESSION):
        print(f"{DIM}Attaching to tmux session '{TMUX_SESSION}'...{RESET}")
        os.execlp("tmux", "tmux", "attach-session", "-t", TMUX_SESSION)
    else:
        ce_path = str(Path(__file__).resolve())
        args = [sys.executable, ce_path] + sys.argv[1:]
        print(f"{DIM}Creating tmux session '{TMUX_SESSION}'...{RESET}")
        os.execlp("tmux", "tmux", "new-session", "-s", TMUX_SESSION, *args)


def start_ccbot() -> None:
    """Start ccbot Telegram bridge."""
    if not CCBOT_DIR.exists():
        print(f"{YELLOW}⚠ ccbot config not found: {CCBOT_DIR}{RESET}")
        print(f"{DIM}Run: mkdir ~/.ccbot && chezmoi apply ~/.ccbot/.env{RESET}")
        sys.exit(1)
    # Pre-load .env into os.environ so ccbot finds vars regardless of cwd
    env_file = CCBOT_DIR / ".env"
    if env_file.exists():
        for line in env_file.read_text().splitlines():
            line = line.strip()
            if line.startswith("export "):
                line = line[7:].strip()
            if line and not line.startswith("#") and "=" in line:
                key, _, value = line.partition("=")
                val = value.strip()
                if len(val) >= 2 and val[0] == val[-1] and val[0] in ('"', "'"):
                    val = val[1:-1]
                os.environ.setdefault(key.strip(), val)
    try:
        os.execlp("ccbot", "ccbot")
    except FileNotFoundError:
        print(
            f"{YELLOW}⚠ ccbot not found. Install:{RESET}"
            f" {DIM}uv tool install git+https://github.com/six-ddc/ccbot.git{RESET}"
        )
        sys.exit(1)


def apply_persistent_env(env_dict: dict) -> dict:
    """Ensure persistent env vars are present in an env dict."""
    for key, value in PERSISTENT_ENV.items():
        env_dict.setdefault(key, value)
    return env_dict


def get_cliproxy_url() -> str:
    """Get CLIProxyAPI base URL, respecting CLIPROXY_PORT env var."""
    port = os.environ.get("CLIPROXY_PORT", "8317")
    return f"http://127.0.0.1:{port}"


